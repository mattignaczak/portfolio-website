{
	"name": "Portfolio Website",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1": {},
		"ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {
			"moby": false
		},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/localstack/devcontainer-feature/localstack-cli:0.1.3": {}
	},
	"mounts": [
		"source=${localEnv:HOME}/.aws,target=/home/node/.aws,type=bind,consistency=cached"
	],
	"postCreateCommand": "npm_config_min_release_age=0 npm ci",
	"customizations": {
		"vscode": {
			"extensions": [
				"amazonwebservices.aws-toolkit-vscode",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"ms-azuretools.vscode-docker"
			]
		}
	}
}
