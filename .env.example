# Template — copy to .env.<environment> (e.g. .env.sandbox) and fill in real values.
# The real .env.* files are gitignored; THIS file is committed as documentation.
#
# DEPLOY_ENV is required, one of: prod | staging | sandbox | test
DEPLOY_ENV=

# Primary site domain (apex) for this environment. The CloudFront distribution
# serves both this and its www. subdomain. e.g. sandbox.mattignaczak.xyz
SITE_DOMAIN_NAME=

# ACM certificate ARN covering SITE_DOMAIN_NAME and www.<SITE_DOMAIN_NAME>.
# MUST be issued in us-east-1 — CloudFront only reads certs from that region.
ACM_CERT_ARN=

# Real secrets do NOT belong here — use GitHub Actions secrets (CI) or
# AWS SSM / Secrets Manager (runtime). See ENVIRONMENT.md.
