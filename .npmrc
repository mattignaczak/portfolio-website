# Supply-chain cooldown: refuse to resolve dependency versions published less
# than 7 days ago. Blunts "publish-malware-then-yank" attacks that rely on you
# pulling a freshly-compromised version within hours of release.
#
# Scope: affects version *resolution* (`npm install <pkg>`, `npm update`). A
# `npm ci` installs the already-vetted lockfile verbatim, so this guards the
# moment you add/bump a dependency. Requires npm >= 11 (older npm ignores it
# with a warning). Workspace packages are file-linked, not fetched, so they're
# unaffected and need no exclude.
min-release-age=7
