# Supply-chain cooldown: refuse to resolve dependency versions published less
# than 7 days ago. Blunts "publish-malware-then-yank" attacks that rely on you
# pulling a freshly-compromised version within hours of release.
#
# Scope: this guards the moment you add/bump a dependency via `npm install <pkg>`
# / `npm update`. Requires npm >= 11 (older npm ignores it with a warning).
# Workspace packages are file-linked, not fetched, so they're unaffected.
#
# Caveat: on npm 11 the cooldown ALSO filters versions during `npm ci`, so a
# lockfile that pins a version younger than the cutoff fails with ETARGET — it is
# NOT exempt despite installing the lockfile verbatim. Our `npm ci` call sites
# (.devcontainer/devcontainer.json, .github/workflows/ci-cd.yml,
# .github/actions/deploy-cdk/action.yml) therefore override it with
# `npm_config_min_release_age=0`.
min-release-age=7
