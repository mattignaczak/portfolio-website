{
  "name": "portfolio-website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "infra",
    "src/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "env:push": "dotenv-vault push",
    "env:pull": "dotenv-vault pull && npm run env:link",
    "env:open": "dotenv-vault open",
    "env:link": "for dir in infra src/api src/web; do [ -d \"$dir\" ] && ln -sf \"$(pwd)/.env\" \"$dir/.env\"; done",
    "prepare": "husky", 
    "build:web":"npm run build -w web", 
    "deploy":"npm run build:web && cd infra && npx cdk deploy"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "dotenv-vault": "^1.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsconfig-paths": "^4.2.0"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --check"
    ]
  }
}
