{
  "name": "portfolio-website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "infra",
    "src/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "prepare": "husky",
    "build:web": "npm run build -w web",
    "deploy": "npm run build:web && cd infra && npx cdk deploy",
    "deploy:sandbox": "set -a; . ./.env.sandbox; set +a; npm run deploy",
    "deploy:staging": "set -a; . ./.env.staging; set +a; npm run deploy",
    "deploy:prod": "set -a; . ./.env.prod; set +a; npm run deploy",
    "cdk:synth": "cd infra && npx cdk synth",
    "cdk:diff": "cd infra && npx cdk diff",
    "synth": "set -a; . ./.env.sandbox; set +a; npm run cdk:synth",
    "diff:prod": "set -a; . ./.env.prod; set +a; npm run cdk:diff"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsconfig-paths": "^4.2.0"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --check"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "headroom-ai": "^0.22.4",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1"
  }
}
